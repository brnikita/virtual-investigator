# =============================================================================
# Virtual Investigator — environment variables
# Copy to .env.local for development. Set the same keys in Vercel for production.
# Cost-sensitive defaults documented in docs/COSTS.md.
# =============================================================================

# ----- Public site -----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ----- OpenAI -----
OPENAI_API_KEY=
# Realtime model. Default to mini to stay under $1/interview budget.
# Switch to "gpt-realtime" for premium quality at ~2x the cost.
OPENAI_REALTIME_MODEL=gpt-realtime-mini
# Image model for dossier portraits.
OPENAI_IMAGE_MODEL=gpt-image-2
# Image quality: low | medium | high. medium ≈ $0.05/image.
OPENAI_IMAGE_QUALITY=medium

# ----- Simli (talking avatar) -----
SIMLI_API_KEY=
# faceId of the friendly cartoon detective avatar (configure in Simli dashboard).
SIMLI_FACE_ID=

# ----- Optional: hard cost guardrails -----
# Maximum interview duration in seconds. The client auto-ends at this point.
MAX_INTERVIEW_SECONDS=300
# Hard cap on images generated per case.
MAX_IMAGES_PER_CASE=3
